{
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/clientReview/(.*)",
      "destination": "/clientReview/index.html"
    },
    {
      "source": "/reviewdash/(.*)",
      "destination": "/reviewdash/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/clientReview/index.html"
    }
  ]
}
